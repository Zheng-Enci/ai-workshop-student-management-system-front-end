2.2.2 动画回调与链式调用设计
动画执行完毕后，通常需要执行回调函数，例如播放下一个动画或更新状态。此外，链式调用（Chaining）允许我们连续播放多个动画，形成动画序列。

示例：添加回调与链式调用
function animateLeft(element, targetLeft, duration, callback) {
    const start = performance.now();
    const startLeft = parseFloat(getComputedStyle(element).left);
 
    function step(currentTime) {
        const elapsed = currentTime - start;
        const progress = Math.min(elapsed / duration, 1);
        const currentLeft = startLeft + (targetLeft - startLeft) * progress;
        element.style.left = currentLeft + 'px';
 
        if (progress < 1) {
            requestAnimationFrame(step);
        } else {
            if (callback) callback();
        }
    }
 
    requestAnimationFrame(step);
}
 
// 链式调用示例
animateLeft(box, 300, 1000, () => {
    animateLeft(box, 0, 1000, () => {
        alert('动画结束');
    });
});
