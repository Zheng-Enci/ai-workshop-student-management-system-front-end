2.3.2 随机扰动算法 与动态偏移模拟
火焰的动态效果来源于随机扰动。我们使用正弦波与随机数混合的方式模拟火焰的抖动。

function updateFlame() {
    const time = performance.now() * 0.001; // 时间归一化
    flameState.offsetX = Math.sin(time * flameState.speed) * flameState.amplitude * Math.random();
    flameState.offsetY = Math.sin(time * flameState.speed * 1.3) * flameState.amplitude * 0.8 * Math.random();
 
    flameElement.style.transform = `
        translate(${flameState.offsetX}px, ${flameState.offsetY}px)
        scale(${flameState.scale})
    `;
    flameElement.style.opacity = flameState.opacity;
 
    requestAnimationFrame(updateFlame);
}
 
updateFlame();
