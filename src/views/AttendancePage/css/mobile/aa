2.2 动画状态与行为控制
在复杂动画系统中，仅实现动画播放是不够的。还需要支持播放、暂停、重置、回调、链式调用等功能，以满足多样化的交互需求。

2.2.1 动画播放、暂停与重置功能实现
除了基本的播放控制，我们还需要实现动画的 暂停 与 重置 功能，使得动画可以被中断或重新开始。

示例：实现播放、暂停与重置的动画控制器
class AnimationController {
    constructor(element) {
        this.element = element;
        this.isPlaying = false;
        this.position = 0;
        this.animationId = null;
    }
 
    start() {
        this.isPlaying = true;
        const startTime = performance.now();
        const duration = 1000;
 
        const animate = (time) => {
            const elapsed = time - startTime;
            const progress = Math.min(elapsed / duration, 1);
            this.position = progress * 300;
            this.element.style.left = this.position + 'px';
 
            if (progress < 1 && this.isPlaying) {
                this.animationId = requestAnimationFrame(animate);
            }
        };
 
        this.animationId = requestAnimationFrame(animate);
    }
 
    pause() {
        this.isPlaying = false;
        cancelAnimationFrame(this.animationId);
    }
 
    reset() {
        this.pause();
        this.position = 0;
        this.element.style.left = '0px';
    }
}
 
// 使用示例
const box = document.getElementById('box');
const controller = new AnimationController(box);
 
document.getElementById('startBtn').addEventListener('click', () => controller.start());
document.getElementById('pauseBtn').addEventListener('click', () => controller.pause());
document.getElementById('resetBtn').addEventListener('click', () => controller.reset());
