    opacity: 0.9;
  }
  70% {
    transform: scale(1.05) translateY(-5px) rotate(-1deg);
    opacity: 0.8;
  }
  100% {
    transform: scale(0.95) translateY(-15px) rotate(0deg);
    opacity: 0;
  }
}
