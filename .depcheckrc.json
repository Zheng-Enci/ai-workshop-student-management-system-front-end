{
	"ignoreMatches": [
		"@babel/*",
		"@typescript-eslint/*",
		"@vitejs/*",
		"@commitlint/*",
		"eslint-*",
		"stylelint-*",
		"vite-plugin-*",
		"rollup-plugin-*",
		"postcss-*",
		"@fullcalendar/*",
		"@element-plus/*",
		"echarts-*",
		"vue3-*"
	],
	"ignorePatterns": [
		"dist",
		"node_modules",
		"*.config.js",
		"*.config.ts",
		"vite.config.js",
		"prettier.config.js",
		"commitlint.config.js",
		".husky/**",
		"scripts/**"
	],
	"ignore": [
		"husky",
		"lint-staged",
		"vue",
		"vue-router",
		"pinia",
		"element-plus",
		"@element-plus/icons-vue",
		"axios",
		"echarts",
		"echarts-wordcloud",
		"@fullcalendar/core",
		"@fullcalendar/daygrid",
		"@fullcalendar/interaction",
		"@fullcalendar/vue3",
		"vue3-lazy",
		"core-js",
		"vite",
		"@vitejs/plugin-vue",
		"vite-plugin-eslint",
		"vite-plugin-stylelint",
		"rollup-plugin-visualizer",
		"@babel/core",
		"@babel/eslint-parser",
		"@babel/preset-env",
		"@typescript-eslint/eslint-plugin",
		"@typescript-eslint/parser",
		"typescript",
		"ts-loader",
		"vue-eslint-parser",
		"prettier",
		"stylelint",
		"stylelint-config-recess-order",
		"stylelint-config-standard",
		"stylelint-declaration-block-no-ignored-properties",
		"stylelint-high-performance-animation",
		"stylelint-order",
		"stylelint-scss",
		"postcss-html",
		"postcss-scss",
		"purgecss",
		"@commitlint/cli",
		"@commitlint/config-conventional",
		"depcheck",
		"playwright"
	],
	"ignoreDeps": [
		"husky",
		"lint-staged",
		"vue",
		"vue-router",
		"pinia",
		"element-plus",
		"@element-plus/icons-vue",
		"axios",
		"echarts",
		"echarts-wordcloud",
		"@fullcalendar/core",
		"@fullcalendar/daygrid",
		"@fullcalendar/interaction",
		"@fullcalendar/vue3",
		"vue3-lazy",
		"core-js",
		"vite",
		"@vitejs/plugin-vue",
		"vite-plugin-eslint",
		"vite-plugin-stylelint",
		"rollup-plugin-visualizer",
		"@babel/core",
		"@babel/eslint-parser",
		"@babel/preset-env",
		"@typescript-eslint/eslint-plugin",
		"@typescript-eslint/parser",
		"typescript",
		"ts-loader",
		"vue-eslint-parser",
		"prettier",
		"stylelint",
		"stylelint-config-recess-order",
		"stylelint-config-standard",
		"stylelint-declaration-block-no-ignored-properties",
		"stylelint-high-performance-animation",
		"stylelint-order",
		"stylelint-scss",
		"postcss-html",
		"postcss-scss",
		"purgecss",
		"@commitlint/cli",
		"@commitlint/config-conventional",
		"depcheck",
		"playwright"
	],
	"detectors": [
		"depcheck-detector-typescript",
		"depcheck-detector-vue",
		"depcheck-detector-es6",
		"depcheck-detector-jsx"
	],
	"parsers": {
		"*.js": ["es6", "jsx"],
		"*.jsx": ["es6", "jsx"],
		"*.ts": ["typescript"],
		"*.tsx": ["typescript", "jsx"],
		"*.vue": ["vue"]
	},
	"specials": [
		"eslint",
		"babel",
		"typescript",
		"webpack",
		"vite",
		"rollup"
	]
}
